{
  "name": "katamarijs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "e2e": "playwright test",
    "assets:validate": "node scripts/validate-assets.mjs",
    "assets:prompts": "node scripts/generate-asset-prompts.mjs --out docs/asset-prompts.generated.md",
    "assets:build-one": "node scripts/build-asset.mjs --id pickup.apple.v2",
    "assets:build": "node scripts/build-asset.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "jsdom": "^27.0.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "three": "^0.183.2",
    "zod": "^4.3.6"
  }
}
